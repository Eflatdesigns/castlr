[Unit]
Description=Castlr Next.js App
After=network.target

[Service]
Type=simple
User=www-data
WorkingDirectory=/var/www/castlr
ExecStart=/usr/bin/node server.js
Restart=always
RestartSec=5
Environment=NODE_ENV=production
EnvironmentFile=/var/www/castlr/.env.production

[Install]
WantedBy=multi-user.target
